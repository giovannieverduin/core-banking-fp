# ── Core Banking — server environment ────────────────────────────────
# Copy to .env (gitignored) and fill in. Never commit real values.

# HTTP server bind address and port for the dashboard/API.
HOST=127.0.0.1
PORT=3000

# Admin API key guarding privileged endpoints.
# If left unset, the server generates a random key at startup (printed to
# the log) — fine for local runs. Set an explicit value for any shared
# or deployed instance. Never hardcode a real key in source.
ADMIN_API_KEY=
